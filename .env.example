# SkyBridge Skills Verifier
# Development environment examples

# Deployment context: 'dev' (default), 'aws', or 'test'
# See docs/deployment.md
CONTEXT=dev

# Pino log level for local dev (trace | debug | info | warn | error | fatal | silent)
# LOG_LEVEL=info

# Credential Engine (required for real framework/skill search on AWS)
# Handbook: https://credreg.net/registry/searchapi
#
# Optional: if unset, fake skill search is used
#
# CREDENTIAL_ENGINE_SEARCH_URL=https://sandbox.credentialengine.org/assistant/search/ctdl
# CREDENTIAL_ENGINE_API_KEY=

# DynamoDB — used when CONTEXT=aws (required in ECS). Ignored for dev/test (in-memory).
#
# DYNAMODB_TABLE=skills-verifier-staging
# AWS_REGION=us-west-2

# Seed demo jobs in MemoryDatabase on dev (default true)
# Set to false/no/0 to skip seeding (e.g. some integration tests)
# SEED_MEMORY_DATABASE=false
