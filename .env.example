# SkyBridge Skills Verifier
# Development environment examples

# Deployment context: 'dev' (default), 'aws', or 'test'
# See docs/deployment.md
CONTEXT=dev

# Pino log level for local dev (trace | debug | info | warn | error | fatal | silent)
# LOG_LEVEL=info

# Credential Engine (required for real framework/skill search on AWS)
# Handbook: https://credreg.net/registry/searchapi
#
# Optional: if unset, fake skill search is used
#
# CREDENTIAL_ENGINE_SEARCH_URL=https://sandbox.credentialengine.org/assistant/search/ctdl
# CREDENTIAL_ENGINE_API_KEY=

# DynamoDB — used when CONTEXT=aws (required in ECS). Ignored for dev/test (in-memory).
#
# DYNAMODB_TABLE=skills-verifier-staging
# AWS_REGION=us-west-2

# Seed demo jobs in MemoryDatabase on dev (default true)
# Set to false/no/0 to skip seeding (e.g. some integration tests)
# SEED_MEMORY_DATABASE=false

# DCC transaction service (verification exchange). If unset on dev, a fake exchange is used.
# TRANSACTION_SERVICE_BASEURI=http://localhost:4004
# TRANSACTION_SERVICE_TENANT=default
# TRANSACTION_SERVICE_TOKEN=
# Public origin wallets must reach for the interact URL (NOT localhost for real phones).
# EXCHANGE_HOST=http://localhost:5173
# Optional comma-separated trusted registries (else DCC defaults apply)
# TRANSACTION_SERVICE_TRUSTED_REGISTRIES=DCC Sandbox Registry

# LearnCard host origin for the partner-connect embed variant
# (?embed=learncard-partner-connect). Exposed to the browser; must be PUBLIC_-prefixed.
# This is the DEFAULT/fallback only. When the LearnCard launch URL carries a valid https
# `lc_host_override` (recovered even from its malformed double-`?` form), that origin takes
# precedence; a non-https or absent override falls back to this value.
# Default: https://learncard.app
# PUBLIC_LEARNCARD_HOST_ORIGIN=https://learncard.app
