# SkyBridge Skills Verifier
# Development environment examples

# Use dev context
CONTEXT=dev

# Credential Engine
# Handbook: https://credreg.net/registry/searchapi
# CREDENTIAL_ENGINE_SEARCH_URL=https://sandbox.credentialengine.org/assistant/search/ctdl
# CREDENTIAL_ENGINE_API_KEY=

# Framework Service Configuration
# Set to 'true' to use fake/mock service (useful for Storybook and testing)
# Set to 'false' to use real HTTP service (fetches from Credential Engine Registry)
# Note: PUBLIC_ prefix is required for client-side access in SvelteKit
PUBLIC_USE_FAKE_FRAMEWORK_SERVICE=false

# Storage
# The app currently always uses an in-memory database (see storage-database-factory).
# DynamoDB env vars are ignored until production persistence is wired back in.
# DYNAMODB_TABLE=skills-verifier-dev
# AWS_REGION=us-east-1
# USE_MEMORY_STORAGE=true

# Skip seeding demo jobs when using MemoryDatabase (e.g. some integration tests).
# SKIP_MEMORY_SEED=true
