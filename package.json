{
	"name": "skills-verifier",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.22.0",
	"scripts": {
		"dev": "vite dev",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"build:svelte": "vite build",
		"build:storybook": "storybook build",
		"check:prettier": "prettier --check .",
		"check:eslint": "eslint .",
		"check:typescript": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"fix:prettier": "prettier --write .",
		"fix:eslint": "eslint . --fix",
		"test:vitest": "vitest",
		"e2e:playwright": "playwright test",
		"dev:storybook": "storybook dev -p 6006"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.39.1",
		"@playwright/test": "^1.57.0",
		"@storybook/addon-a11y": "10.0.2",
		"@storybook/addon-docs": "10.0.2",
		"@storybook/addon-svelte-csf": "^5.0.10",
		"@storybook/sveltekit": "10.0.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.17",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.0.15",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.13.1",
		"globals": "^16.5.0",
		"playwright": "^1.57.0",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"storybook": "10.0.2",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"tailwindcss": "^4.1.17",
		"turbo": "^2.7.6",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.48.1",
		"vite": "^7.2.6",
		"vitest": "^4.0.15",
		"vitest-browser-svelte": "^2.0.1"
	}
}
